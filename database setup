🗄️ Database Setup

The project uses MySQL to store structured data.

 Created relational tables: orders, users, products
 Established relationships using foreign keys
 Imported CSV data into database
 Ensured data integrity and validation

This setup enables efficient querying and analysis.


CREATE DATABASE ecommerce_project;
USE ecommerce_project;
CREATE TABLE orders (
    order_id INT PRIMARY KEY,
    user_id INT,
    product_id INT,
    amount DECIMAL(10,2),
    order_date DATE
);
CREATE TABLE users (
    user_id INT PRIMARY KEY,
    signup_date DATE,
    region VARCHAR(50)
);
CREATE TABLE products (
    product_id INT PRIMARY KEY,
    category VARCHAR(50),
    price DECIMAL(10,2)
);
LOAD DATA INFILE 'path/orders.csv'
INTO TABLE orders
FIELDS TERMINATED BY ','
LINES TERMINATED BY '\n'
IGNORE 1 ROWS;

SELECT COUNT(*) FROM orders;
SELECT COUNT(*) FROM users;
SELECT COUNT(*) FROM products;
SELECT * FROM orders LIMIT 5;

ALTER TABLE orders
ADD FOREIGN KEY (user_id) REFERENCES users(user_id),
ADD FOREIGN KEY (product_id) REFERENCES products(product_id);
